emulator/
├── CMakeLists.txt                 # Top-level CMake for C++ parts
├── README.md
├── .gitignore
├── core/                          # C++ emulator core
│   ├── include/
│   │   ├── cpu.hpp            # CPU class definition
│   │   ├── memory.hpp         # Memory interface
│   │   ├── opcode.hpp          # Common types, instruction unions
│   │   ├── common.hpp          # Common types, instruction unions
│   │   └── assembler.hpp        # Instruction decoding helpers
│   ├── src/
│   │   ├── cpu.cc
│   │   ├── memory.cc
│   │   ├── flags.cc
│   │   ├── execute.cc
│   │   ├── decode.cc
│   │   ├── opcode_table.cc
│   │   ├── fetch.cc
│   └── tests/                     # Unit tests for core (Catch2/GoogleTest)
│       ├── test_cpu.cpp
│       └── CMakeLists.txt
├── assembler/                      # C++ assembler (two-pass)
├── python/                         # Python GUI and bindings
│   ├── riscv_gui/
│   │   ├── __init__.py
│   │   ├── main_window.py          # PyQt main window
│   │   ├── find_dialog.py 
│   │   ├── replace_dialog.py        # Register table display
│   │   └── main.py             
